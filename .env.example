# PostgreSQL connection string (Supabase, Neon, or local)
DATABASE_URL=postgresql://user:password@host:5432/verikey

# Your verified domain (used as WebAuthn Relying Party ID)
NEXT_PUBLIC_BASE_URL=https://yourdomain.com
WEBAUTHN_RP_ID=yourdomain.com
WEBAUTHN_RP_NAME=VeriKey

# Secret for signing challenge cookies (generate: openssl rand -hex 32)
CHALLENGE_SECRET=replace_with_random_hex_string

# Secret key for server-side HMAC-SHA256 hashing of phone numbers (generate: openssl rand -hex 32)
# Changing this key invalidates all existing passkeys — all users must re-register.
PHONE_HMAC_SECRET=replace_with_random_hex_string

# Mobile app API URL (set in mobile/.env or Expo config)
EXPO_PUBLIC_API_URL=https://yourdomain.com
