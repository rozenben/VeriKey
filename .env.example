# PostgreSQL connection string (Neon, Supabase, or local)
DATABASE_URL=postgresql://user:password@host:5432/verikey

# Your public URL — baked into the client bundle at build time.
# Must match your Vercel deployment URL exactly.
NEXT_PUBLIC_BASE_URL=https://my-app.vercel.app

# WebAuthn Relying Party settings
# WEBAUTHN_RP_ID: domain only, no protocol (e.g. my-app.vercel.app)
# Use "localhost" for local development.
WEBAUTHN_RP_ID=my-app.vercel.app
WEBAUTHN_RP_NAME=VeriKey

# Secret for signing WebAuthn challenges (generate: openssl rand -hex 32)
CHALLENGE_SECRET=replace_with_random_hex_string

# HMAC secret for hashing email addresses into stable identifiers
# WARNING: changing this invalidates all existing user accounts.
# Generate: openssl rand -hex 32
IDENTIFIER_HMAC_SECRET=replace_with_random_hex_string

# AES-256 key for encrypting stored email addresses
# Generate: openssl rand -hex 32
EMAIL_ENCRYPTION_KEY=replace_with_random_hex_string

# Resend API key — required for OTP delivery and result emails
# Get one at https://resend.com
RESEND_API_KEY=re_...
